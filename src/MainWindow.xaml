<Window x:Class="NanoCADModuleManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NanoCADModuleManager"
        mc:Ignorable="d"
        Title="nanoCAD Module Manager" Height="600" Width="1000">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left Panel: nanoCAD Versions -->
        <StackPanel Grid.Column="0" Margin="5">
            <Label Content="nanoCAD Versions:" FontWeight="Bold" />
            <ListBox x:Name="VersionsListBox" SelectionChanged="VersionsListBox_SelectionChanged" Height="Auto"/>
        </StackPanel>
        
        <!-- Right Panel: Modules Table -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <Label Grid.Row="0" Content="Modules for Selected Version:" FontWeight="Bold" />
            
            <DataGrid x:Name="ModulesDataGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" CellEditEnding="ModulesDataGrid_CellEditEnding">
                <DataGrid.Columns>
                    <!-- Column 1: Module Name -->
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    
                    <!-- Column 2: Compatible Configurations (with icons) -->
                    <DataGridTemplateColumn Header="Configurations" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ItemsControl ItemsSource="{Binding CompatibleConfigs}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="LightGray" Padding="5,2" Margin="2" CornerRadius="3">
                                                <TextBlock Text="{Binding}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    
                    <!-- Column 3: Description -->
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    
                    <!-- Column 4: Is Loaded (Checkbox) -->
                    <DataGridTemplateColumn Header="Load" Width="60">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsLoaded, Mode=TwoWay}" HorizontalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>
